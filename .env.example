 # Postgres connection string (e.g. from Render or Supabase)
 DATABASE_URL="supabase_url"

 # Brevo (https://www.brevo.com) HTTP API — used to send OTP emails.
 # Render's free tier blocks outbound SMTP, so OTPs are sent via Brevo's
 # HTTPS API instead of smtplib.
 BREVO_API_KEY="your-brevo-api-key"
 BREVO_SENDER_EMAIL="your-verified-sender@example.com"

 # Used to sign admin and vote session tokens (HMAC-SHA256). Generate one
 # with: python -c "import secrets; print(secrets.token_hex(32))"
 # If this isn't set, the app still boots but every restart invalidates
 # all active admin/vote sessions — set this for real deployments.
 APP_SECRET_KEY="replace-with-a-long-random-string"

 # Password required to access the Election Control Center (/admin).
 # Pick something only the election administrator(s) know.
 ADMIN_PASSWORD="replace-with-a-strong-password"
